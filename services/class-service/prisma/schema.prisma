generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ClassroomType {
  TEACHING
  FRIENDLY
}

enum Role {
  ADMIN
  MEMBER
}

model Classroom {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  type        ClassroomType
  classCode   String        @unique @map("class_code") @db.VarChar(6)
  description String?
  subject     String?
  section     String?
  coverImage  String?       @map("cover_image")
  chatEnabled Boolean       @default(true) @map("chat_enabled")
  creatorId   String        @map("creator_id") @db.Uuid
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  members  Member[]
  chapters Chapter[]

  @@index([creatorId])
  @@map("classrooms")
}

model Member {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role     @default(MEMBER)
  joinedAt  DateTime @default(now()) @map("joined_at")

  classroom Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, userId])
  @@index([classId])
  @@index([userId])
  @@map("members")
}

model Chapter {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @map("class_id") @db.Uuid
  name      String
  position  Int      @default(0)
  isGeneral Boolean  @default(false) @map("is_general")
  createdAt DateTime @default(now()) @map("created_at")

  classroom Classroom @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([classId])
  @@map("chapters")
}
