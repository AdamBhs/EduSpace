generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ChatRoom {
  id        String   @id @default(uuid()) @db.Uuid
  classId   String   @unique @map("class_id") @db.Uuid
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  messages   Message[]
  readStates ChatReadState[]

  @@map("chat_rooms")
}

model Message {
  id         String    @id @default(uuid()) @db.Uuid
  chatRoomId String    @map("chat_room_id") @db.Uuid
  senderId   String    @map("sender_id") @db.Uuid
  content    String?
  fileKey    String?   @map("file_key")
  fileName   String?   @map("file_name")
  pinnedAt   DateTime? @map("pinned_at")
  pinnedBy   String?   @map("pinned_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at")

  chatRoom  ChatRoom          @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]

  @@index([chatRoomId, createdAt])
  @@index([chatRoomId, pinnedAt])
  @@index([senderId])
  @@map("messages")
}

model MessageReaction {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("message_reactions")
}

model ChatReadState {
  id         String   @id @default(uuid()) @db.Uuid
  chatRoomId String   @map("chat_room_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  lastReadAt DateTime @default(now()) @map("last_read_at")

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)

  @@unique([chatRoomId, userId])
  @@index([chatRoomId])
  @@map("chat_read_states")
}

model DirectConversation {
  id             String   @id @default(uuid()) @db.Uuid
  participant1Id String   @map("participant1_id") @db.Uuid
  participant2Id String   @map("participant2_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  messages   DirectMessage[]
  readStates DirectReadState[]

  @@unique([participant1Id, participant2Id])
  @@index([participant1Id])
  @@index([participant2Id])
  @@map("direct_conversations")
}

model DirectMessage {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  content        String?
  fileKey        String?   @map("file_key")
  fileName       String?   @map("file_name")
  pinnedAt       DateTime? @map("pinned_at")
  pinnedBy       String?   @map("pinned_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at")

  conversation DirectConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  reactions    DirectMessageReaction[]

  @@index([conversationId, createdAt])
  @@index([conversationId, pinnedAt])
  @@index([senderId])
  @@map("direct_messages")
}

model DirectMessageReaction {
  id              String   @id @default(uuid()) @db.Uuid
  directMessageId String   @map("direct_message_id") @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  emoji           String
  createdAt       DateTime @default(now()) @map("created_at")

  directMessage DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)

  @@unique([directMessageId, userId, emoji])
  @@index([directMessageId])
  @@map("direct_message_reactions")
}

model DirectReadState {
  id             String   @id @default(uuid()) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  lastReadAt     DateTime @default(now()) @map("last_read_at")

  conversation DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@map("direct_read_states")
}
