generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum NotificationType {
  POST_CREATED
  ASSIGNMENT_DUE
  SUBMISSION_GRADED
  MEMBER_JOINED_DEPRECATED @map("MEMBER_JOINED_DEPRECATED")
  MEMBER_REMOVED_DEPRECATED @map("MEMBER_REMOVED_DEPRECATED")
  ROLE_CHANGED_DEPRECATED @map("ROLE_CHANGED_DEPRECATED")
  CHAT_MESSAGE
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String
  body      String?
  classId   String?          @map("class_id") @db.Uuid
  postId    String?          @map("post_id") @db.Uuid
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}
